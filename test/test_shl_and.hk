fn main() -> int {
  // Test << operator
  let x: int = 1 << 3
  // x should be 8

  // Test short-circuit && (left side false, right side should NOT be evaluated)
  let y: int = 0 && (1 / 0)
  // y should be 0 (no division by zero because right side is skipped)

  // Test short-circuit && (left side true, right side evaluated)
  let z: int = 1 && 2
  // z should be 1 (both truthy)

  // Test short-circuit && (both false)
  let w: int = 0 && 0
  // w should be 0

  return x + y + z + w
}