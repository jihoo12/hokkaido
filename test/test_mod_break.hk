extern fn printf(fmt: string, ...) -> int

fn main() -> int {
    // Test modulo
    let a: int = 17
    let b: int = 5
    let m: int = a % b
    printf("17 %% 5 = %ld\n", m)       // expect 2

    // Test compound modulo
    let x: int = 20
    x %= 7
    printf("20 %% 7 = %ld\n", x)     // expect 6

    // Test break
    let i: int = 0
    for ; ; {
        if i >= 3 {
            break
        }
        i = i + 1
    }
    printf("after break loop, i = %ld\n", i)  // expect 3

    // Test continue (find first even > 0)
    let found: int = 0
    for let j: int = 1; j <= 20; j = j + 1 {
        let rem: int = j % 2
        if rem != 0 {
            continue
        }
        found = j
        break
    }
    printf("first even >= 1 = %ld\n", found)  // expect 2

    // All features together: sum of evens via modulo
    let sum: int = 0
    for let k: int = 1; k <= 10; k = k + 1 {
        if (k % 2) != 0 {
            continue
        }
        sum = sum + k
    }
    printf("sum of evens 1..10 = %ld\n", sum)  // expect 2+4+6+8+10 = 30

    return 0
}
